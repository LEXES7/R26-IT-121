# ============================================================
# DeepSentinel — VAE-With-DSAA .gitignore
# R26-IT-121 | IT22109194 | Wijesinghe L P D B
# ============================================================

# Redundant .py versions (notebooks are the source of truth)
*.py

# PDF files (proposal, spec docs — too large, not code)
*.pdf

# Data files (too large for GitHub — stored in Google Drive)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.csv

# Saved models and results (too large — stored in Google Drive)
results/*
models/*
DeepSentinel-VAE-Results/
!results/.gitkeep
!models/.gitkeep
*.keras
*.h5
*.pkl
*.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db
